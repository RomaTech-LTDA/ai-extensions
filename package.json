{
  "name": "@romatech/ai-extensions",
  "version": "1.3.0",
  "description": "Plug-and-play AI enablement framework for Node.js APIs. Transforms Express/Fastify/Koa endpoints into MCP tools and RAG-enabled knowledge sources automatically.",
  "author": "RomaTech/Leandro Romanelli",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RomaTech-LTDA/ai-extensions"
  },
  "homepage": "https://github.com/RomaTech-LTDA/ai-extensions#readme",
  "bugs": {
    "url": "https://github.com/RomaTech-LTDA/ai-extensions/issues"
  },
  "keywords": [
    "ai",
    "mcp",
    "model-context-protocol",
    "rag",
    "llm",
    "express",
    "fastify",
    "koa",
    "swagger",
    "openapi",
    "tools",
    "semantic-search",
    "embeddings"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "default": "./dist/mcp/index.js"
    },
    "./rag": {
      "types": "./dist/rag/index.d.ts",
      "default": "./dist/rag/index.js"
    },
    "./metadata": {
      "types": "./dist/metadata/index.d.ts",
      "default": "./dist/metadata/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "default": "./dist/adapters/index.js"
    },
    "./swagger": {
      "types": "./dist/swagger/index.d.ts",
      "default": "./dist/swagger/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc",
    "watch": "tsc --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "size": "npm run build && npm pack --dry-run 2>&1 | tail -1",
    "docs": "typedoc --out docs/api src/index.ts"
  },
  "peerDependencies": {
    "express": ">=4.0.0 || >=5.0.0",
    "reflect-metadata": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "reflect-metadata": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^24.1.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "express": "^5.1.0",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.0.1",
    "typescript": "^6.0.3",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
